# ============================================================
# GradeUp — Variables d'environnement (exemple)
# Copier en `.env` et renseigner les valeurs réelles.
# NEVER committer le vrai `.env` (il contient des secrets).
# ============================================================

# --- Base de données PostgreSQL (Prisma) ---
# DATABASE_URL : pooler (pgbouncer) pour l'app
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# DIRECT_URL : connexion directe (migrations / prisma db push)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- Auth JWT (sessions en cookie HTTP-only) ---
# IMPORTANT : utiliser des secrets longs et aléatoires en production.
JWT_SECRET="change-me-with-a-long-random-string-access"
JWT_REFRESH_SECRET="change-me-with-a-long-random-string-refresh"

# --- Supabase (Realtime + Storage) ---
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-KEY"
# Clé service_role (côté serveur uniquement, jamais exposée au client)
SUPABASE_SERVICE_ROLE_KEY="YOUR-SERVICE-ROLE-KEY"
# Nom du bucket Storage pour les fichiers (cours, devoirs, ressources, logos)
SUPABASE_STORAGE_BUCKET="Gradeup"

# --- IA Gradie ---
# Fournisseur : auto | local | deepseek | openrouter | glm
# GLM (recommandé)
GLM_API_KEY="YOUR-GLM-API-KEY"
GLM_MODEL="glm-4.5-flash"
# OpenRouter (optionnel)
OR_API_KEY="YOUR-OPENROUTER-KEY"
OR_MODEL="deepseek/deepseek-chat-v3-0324:free"
# DeepSeek (optionnel)
DEEPSEEK_API_KEY="YOUR-DEEPSEEK-KEY"

# --- Notifications Push (Web Push / PWA) ---
# Générer une paire VAPID (web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY="YOUR-VAPID-PUBLIC-KEY"
VAPID_PRIVATE_KEY="YOUR-VAPID-PRIVATE-KEY"

# --- Paiements (PawaPay, sandbox en dev) ---
PAWAPAY_API_KEY="sandbox_key_placeholder"
PAWAPAY_API_SECRET="sandbox_secret_placeholder"
