generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model School {
  id                   String                 @id @default(cuid())
  name                 String
  email                String                 @unique
  password             String
  inviteCode           String                 @unique
  currency             String                 @default("USD")
  logoUrl              String                 @default("")
  province             String                 @default("")
  city                 String                 @default("")
  commune              String                 @default("")
  schoolCode           String                 @default("")
  subscriptionStatus   String                 @default("active")
  subscriptionExpiry   DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  attendance           Attendance[]
  courses              Course[]
  courseWithPoints     CourseWithPoints[]
  deliberations        DeliberationDecision[]
  detailedGrades       DetailedGrade[]
  grades               Grade[]
  gradeHistories       GradeHistory[]
  homework             Homework[]
  lessons              Lesson[]
  messages             Message[]
  notifications        Notification[]
  payments             Payment[]
  reportCards          ReportCard[]
  classes              SchoolClass[]
  schedules            CourseSchedule[]
  users                User[]
  videoConferences     VideoConference[]
  ressources            Ressource[]
  latitude             Float?
  longitude            Float?
  presences            Presence[]
  years                SchoolYear[]
}

model SchoolYear {
  id             String    @id @default(cuid())
  schoolId       String
  year           String // ex: "2026-2027"
  status         String    @default("OPEN") // OPEN | CLOSED
  closedById     String?
  closedAt       DateTime?
  transitionData Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  school         School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, year])
}

model User {
  id                      String                 @id @default(cuid())
  schoolId                String
  fullName                String
  email                   String                 @default("")
  password                String
  role                    String                 @default("STUDENT")
  photoUrl                String                 @default("")
  parentCode              String                 @unique
  active                  Boolean                @default(true)
  parentId                String?
  phone                   String                 @default("")
  parentPhone             String                 @default("")
  parentPhone2            String                 @default("")
  cardId                  String?                @unique
  postName                String                 @default("")
  gender                  String                 @default("M")
  birthDate               String                 @default("")
  matricule               String                 @default("")
  academicYear            String                 @default("2025-2026")
  section                 String                 @default("")
  aiPreferences           String                 @default("{}")
  isTitulaire             Boolean                @default(false)
  titulaireClassIds       String[]
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  conversations           AiConversation[]
  attendanceStudent       Attendance[]           @relation("AttendanceStudent")
  attendanceTeacher       Attendance[]           @relation("AttendanceTeacher")
  courses                 Course[]
  deliberations           DeliberationDecision[] @relation("DeliberationStudent")
  deliberationsValidated  DeliberationDecision[] @relation("DeliberationValidator")
  detailedGrades          DetailedGrade[]
  classEnrollments        EnrolledClass[]
  gradesStudent           Grade[]                @relation("GradeStudent")
  gradesTeacher           Grade[]                @relation("GradeTeacher")
  gradeHistoriesModified  GradeHistory[]         @relation("GradeHistoryModifier")
  homework                Homework[]
  lessons                 Lesson[]
  receivedMessages        Message[]              @relation("ReceivedMessages")
  sentMessages            Message[]              @relation("SentMessages")
  notifications           Notification[]         @relation("UserNotifications")
  payments                Payment[]
  pushSubscriptions       PushSubscription[]
  memories                 AiMemory[]
  favoris                  Favori[]
  reportCards             ReportCard[]
  cahierMarks             CahierMark[]
  parent                  User?                  @relation("ParentChild", fields: [parentId], references: [id])
  children                User[]                 @relation("ParentChild")
  school                  School                 @relation(fields: [schoolId], references: [id])
  dernierePresence        DateTime?              @map("derniere_presence")
  presences               Presence[]

  @@unique([schoolId, fullName, role])
}

model SchoolClass {
  id               String             @id @default(cuid())
  schoolId         String
  name             String
  level            String             @default("Primaire")
  fees             Float              @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  courses          Course[]
  courseWithPoints CourseWithPoints[]
  enrollments      EnrolledClass[]
  reportCards      ReportCard[]
  school           School             @relation(fields: [schoolId], references: [id])
}

model EnrolledClass {
  id        String      @id @default(cuid())
  userId    String
  classId   String
  createdAt DateTime    @default(now())
  class     SchoolClass @relation(fields: [classId], references: [id])
  user      User        @relation(fields: [userId], references: [id])

  @@unique([userId, classId])
}

model Course {
  id          String           @id @default(cuid())
  schoolId    String
  classId     String
  teacherId   String
  name        String
  maxScore    Float            @default(20)
  coefficient Int              @default(1)
  description String           @default("")
  status      String           @default("ACTIVE")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  class       SchoolClass      @relation(fields: [classId], references: [id])
  school      School           @relation(fields: [schoolId], references: [id])
  teacher     User             @relation(fields: [teacherId], references: [id])
  grades      Grade[]
  homework    Homework[]
  lessons     Lesson[]
  schedules   CourseSchedule[]
}

model Lesson {
  id        String   @id @default(cuid())
  schoolId  String
  courseId  String
  teacherId String
  title     String
  content   String   @default("")
  fileUrl   String   @default("")
  fileName  String   @default("")
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id])
  school    School   @relation(fields: [schoolId], references: [id])
  teacher   User     @relation(fields: [teacherId], references: [id])
}

model Grade {
  id        String         @id @default(cuid())
  schoolId  String
  courseId  String
  studentId String
  teacherId String
  score     Float
  maxScore  Float          @default(20)
  trimester String         @default("1")
  comment   String         @default("")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  course    Course         @relation(fields: [courseId], references: [id])
  school    School         @relation(fields: [schoolId], references: [id])
  student   User           @relation("GradeStudent", fields: [studentId], references: [id])
  teacher   User           @relation("GradeTeacher", fields: [teacherId], references: [id])
  history   GradeHistory[]
}

model Homework {
  id          String   @id @default(cuid())
  schoolId    String
  courseId    String
  teacherId   String
  title       String
  description String   @default("")
  dueDate     String   @default("")
  gradingType String   @default("manual") // "manual" | "automatic"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  course      Course   @relation(fields: [courseId], references: [id])
  school      School   @relation(fields: [schoolId], references: [id])
  teacher     User     @relation(fields: [teacherId], references: [id])
}

model Attendance {
  id        String   @id @default(cuid())
  schoolId  String
  studentId String
  teacherId String
  date      String
  status    String   @default("absent")
  reason    String   @default("")
  createdAt DateTime @default(now())
  school    School   @relation(fields: [schoolId], references: [id])
  student   User     @relation("AttendanceStudent", fields: [studentId], references: [id])
  teacher   User     @relation("AttendanceTeacher", fields: [teacherId], references: [id])

  @@unique([studentId, date])
}

model Payment {
  id        String   @id @default(cuid())
  schoolId  String
  studentId String
  amount    Float
  status    String   @default("pending")
  month     String   @default("")
  method    String   @default("cash")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id])
  student   User     @relation(fields: [studentId], references: [id])
}

model Message {
  id          String   @id @default(cuid())
  schoolId    String
  senderId    String
  recipientId String
  content     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  recipient   User     @relation("ReceivedMessages", fields: [recipientId], references: [id])
  school      School   @relation(fields: [schoolId], references: [id])
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
}

model Notification {
  id            String   @id @default(cuid())
  schoolId      String
  userId        String?
  senderId      String   @default("")
  title         String   @default("Notification")
  message       String
  type          String   @default("INFO")
  priority      String   @default("NORMAL")
  read          Boolean  @default(false)
  metadata      String   @default("{}")
  targetRole    String   @default("ALL")
  targetClassId String   @default("")
  createdAt     DateTime @default(now())
  school        School   @relation(fields: [schoolId], references: [id])
  user          User?    @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
}

model VideoConference {
  id            String   @id @default(cuid())
  schoolId      String
  title         String
  description   String   @default("")
  date          String
  time          String
  roomUrl       String
  targetRole    String   @default("ALL")
  targetClassId String   @default("")
  type          String   @default("scheduled") // "scheduled" | "instant"
  status        String   @default("scheduled") // "scheduled" | "live" | "ended"
  isLocked      Boolean  @default(false)
  creatorId     String   @default("")
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime @default(now())
  school        School       @relation(fields: [schoolId], references: [id])
  participants  Participant[]
  recordings    Recording[]
}

model Participant {
  id        String   @id @default(cuid())
  meetingId String
  schoolId  String
  userId    String
  fullName  String
  role      String   @default("PARTICIPANT") // "HOST" | "COHOST" | "PARTICIPANT"
  status    String   @default("pending") // "pending" | "approved" | "rejected" | "removed"
  isCoHost  Boolean  @default(false)
  joinedAt  DateTime?
  leftAt    DateTime?
  createdAt DateTime @default(now())
  meeting   VideoConference @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

model Recording {
  id            String   @id @default(cuid())
  meetingId     String
  schoolId      String
  createdById   String
  url           String   @default("")
  note          String   @default("")
  durationSeconds Int    @default(0)
  createdAt     DateTime @default(now())
  meeting       VideoConference @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AiConversation {
  id             String       @id @default(cuid())
  userId         String
  title          String       @default("Nouvelle conversation")
  salutationDone Boolean      @default(false)
  tags           String       @default("") // séparées par des virgules
  favorite       Boolean      @default(false)
  pinned         Boolean      @default(false)
  pinnedAt       DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents      AiDocument[]
  messages       AiMessage[]
}

model AiMemory {
  id        String   @id @default(cuid())
  userId    String
  schoolId  String
  content   String
  category  String   @default("fact") // fact | preference | context
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Ressource {
  id            String   @id @default(cuid())
  schoolId      String
  title         String
  description   String   @default("")
  category      String   @default("Général") // catégorie / sous-catégorie
  matiere       String   @default("") // matière
  niveau        String   @default("") // niveau scolaire
  author        String   @default("")
  url           String   @default("") // URL externe (type LIEN / VIDEO)
  fileUrl       String   @default("") // fichier uploadé (PDF / FICHIER)
  type          String   @default("LIEN") // LIEN | PDF | VIDEO | FICHIER
  visibility    String   @default("PUBLIC") // PUBLIC | ROLE | CLASS
  targetRole    String   @default("ALL")
  targetClassId String   @default("")
  createdById   String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now())
  school        School   @relation(fields: [schoolId], references: [id])
  favoris       Favori[]
}

model Favori {
  id          String   @id @default(cuid())
  userId      String
  ressourceId String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ressource   Ressource @relation(fields: [ressourceId], references: [id], onDelete: Cascade)

  @@unique([userId, ressourceId])
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String
  role           String
  content        String
  createdAt      DateTime       @default(now())
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model AiDocument {
  id             String         @id @default(cuid())
  conversationId String
  name           String
  mimeType       String
  url            String
  size           Int
  extractedText  String         @default("")
  summary        String         @default("")
  createdAt      DateTime       @default(now())
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model ReportCard {
  id                   String      @id @default(cuid())
  reportNumber         String      @unique
  schoolId             String
  classId              String
  studentId            String
  teacherId            String?
  trimester            String
  academicYear         String      @default("2025-2026")
  studentName          String
  studentGender        String
  studentBirthDate     String
  studentPhotoUrl      String      @default("")
  permanentNumber      String      @default("")
  totalPointsObtained  Float
  totalPointsPossible  Float
  overallPercentage    Float
  averageGrade         Float
  classRank            Int
  mention              String
  status               String      @default("draft")
  gradesData           Json
  studentSignatureUrl  String      @default("")
  parentSignatureUrl   String      @default("")
  teacherSignatureUrl  String      @default("")
  directorSignatureUrl String      @default("")
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  class                SchoolClass @relation(fields: [classId], references: [id])
  school               School      @relation(fields: [schoolId], references: [id])
  student              User        @relation(fields: [studentId], references: [id])

  @@unique([schoolId, reportNumber])
}

model ReportCounter {
  id           String   @id @default(cuid())
  year         Int      @unique
  currentCount Int      @default(0)
  maxLimit     Int      @default(1000000)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CourseSchedule {
  id          String    @id @default(cuid())
  courseId    String
  schoolId    String
  dayOfWeek   Int       // 1=Lundi, 2=Mardi, 3=Mercredi, 4=Jeudi, 5=Vendredi, 6=Samedi
  startTime   String    // ex: "08:30"
  endTime     String    // ex: "10:00"
  room        String    @default("")
  periodStart DateTime?
  periodEnd   DateTime?
  exceptions  String    @default("[]")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  school      School    @relation(fields: [schoolId], references: [id])
}

model GradeHistory {
  id         String   @id @default(cuid())
  gradeId    String
  schoolId   String
  oldScore   Float
  newScore   Float
  modifiedBy String
  reason     String   @default("")
  createdAt  DateTime @default(now())
  grade      Grade    @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  school     School   @relation(fields: [schoolId], references: [id])
  modifier   User     @relation("GradeHistoryModifier", fields: [modifiedBy], references: [id])
}

model DeliberationDecision {
  id           String   @id @default(cuid())
  schoolId     String
  studentId    String
  classId      String
  academicYear String
  decision     String   // "passage" | "redoublement" | "en_deliberation" | "admis_apres_deliberation" | "non_admis"
  validatedBy  String
  comment      String   @default("")
  decidedAt    DateTime @default(now())
  student      User     @relation("DeliberationStudent", fields: [studentId], references: [id])
  school       School   @relation(fields: [schoolId], references: [id])
  validator    User     @relation("DeliberationValidator", fields: [validatedBy], references: [id])
}

model EPSTCurriculum {
  id          String   @id @default(cuid())
  section     String   // ex: "Scientifique", "Littéraire", "Commerciale"
  option      String   @default("") // ex: "Chimie-Bio", "Langue des affaires"
  level       String   // ex: "5ème", "6ème", "7ème"
  courseName  String
  maxScore    Float    @default(20)
  coefficient Int      @default(1)
  isOfficial  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([section, option, level, courseName])
}

model CourseWithPoints {
  id               String          @id @default(cuid())
  schoolId         String
  classId          String
  name             String
  points           Int             @default(1)
  maxScore         Float           @default(20)
  trimester1Weight Float           @default(0.5)
  trimester2Weight Float           @default(0.5)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  class            SchoolClass     @relation(fields: [classId], references: [id])
  school           School          @relation(fields: [schoolId], references: [id])
  detailedGrades   DetailedGrade[]
}

model DetailedGrade {
  id        String           @id @default(cuid())
  schoolId  String
  studentId String
  courseId  String
  trimester String
  semester  String
  dailyWork Float            @default(0)
  exam      Float            @default(0)
  total     Float            @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  course    CourseWithPoints @relation(fields: [courseId], references: [id])
  school    School           @relation(fields: [schoolId], references: [id])
  student   User             @relation(fields: [studentId], references: [id])

  @@unique([studentId, courseId, trimester, semester])
}

model Presence {
  id            String   @id @default(cuid())
  schoolId      String   @map("school_id")
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date          DateTime @default(now())
  heureArrivee  DateTime @map("heure_arrivee")
  statut        String   // PRESENT, RETARD, ABSENT, JUSTIFIE
  justification String?  // Si justification fournie
  validePar     String?  @map("valide_par") // Admin qui valide la justification
  latitude      Float?
  longitude     Float?
  creeLe        DateTime @default(now()) @map("cree_le")
  modifieLe     DateTime @updatedAt @map("modifie_le")

  @@unique([userId, date])
  @@map("presences")
}

model CahierEvaluation {
  id        String       @id @default(cuid())
  schoolId  String
  classId   String
  courseId  String
  title     String
  maxScore  Float        @default(20)
  period    String       // "P1" | "P2" | "EX1" | "P3" | "P4" | "EX2"
  date      DateTime     @default(now())
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  marks     CahierMark[]
}

model CahierMark {
  id           String           @id @default(cuid())
  evaluationId String
  studentId    String
  score        Float
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  evaluation   CahierEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  student      User             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, studentId])
}

