generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model School {
  id               String            @id @default(cuid())
  name             String
  email            String            @unique
  password         String
  inviteCode       String            @unique
  currency         String            @default("USD")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  attendance       Attendance[]
  courses          Course[]
  grades           Grade[]
  homework         Homework[]
  lessons          Lesson[]
  messages         Message[]
  notifications    Notification[]
  payments         Payment[]
  classes          SchoolClass[]
  users            User[]
  videoConferences VideoConference[]
}

model User {
  id                String          @id @default(cuid())
  schoolId          String
  fullName          String
  email             String          @default("")
  password          String
  role              String          @default("STUDENT")
  photoUrl          String          @default("")
  parentCode        String          @unique
  active            Boolean         @default(true)
  parentId          String?
  phone             String          @default("")
  parentPhone       String          @default("")
  parentPhone2      String          @default("")
  cardId            String?         @unique
  postName          String          @default("")
  gender            String          @default("M")
  birthDate         String          @default("")
  matricule         String          @default("")
  academicYear      String          @default("2025-2026")
  section           String          @default("")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  attendanceStudent Attendance[]    @relation("AttendanceStudent")
  attendanceTeacher Attendance[]    @relation("AttendanceTeacher")
  courses           Course[]
  classEnrollments  EnrolledClass[]
  gradesStudent     Grade[]         @relation("GradeStudent")
  gradesTeacher     Grade[]         @relation("GradeTeacher")
  homework          Homework[]
  lessons           Lesson[]
  receivedMessages  Message[]       @relation("ReceivedMessages")
  sentMessages      Message[]       @relation("SentMessages")
  notifications     Notification[]  @relation("UserNotifications")
  payments          Payment[]
  parent            User?           @relation("ParentChild", fields: [parentId], references: [id])
  children          User[]          @relation("ParentChild")
  school            School          @relation(fields: [schoolId], references: [id])
  pushSubscriptions PushSubscription[]

  @@unique([schoolId, fullName, role])
}

model SchoolClass {
  id          String          @id @default(cuid())
  schoolId    String
  name        String
  level       String          @default("Primaire")
  fees        Float           @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  courses     Course[]
  enrollments EnrolledClass[]
  school      School          @relation(fields: [schoolId], references: [id])
}

model EnrolledClass {
  id        String      @id @default(cuid())
  userId    String
  classId   String
  createdAt DateTime    @default(now())
  class     SchoolClass @relation(fields: [classId], references: [id])
  user      User        @relation(fields: [userId], references: [id])

  @@unique([userId, classId])
}

model Course {
  id          String      @id @default(cuid())
  schoolId    String
  classId     String
  teacherId   String
  name        String
  description String      @default("")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  class       SchoolClass @relation(fields: [classId], references: [id])
  school      School      @relation(fields: [schoolId], references: [id])
  teacher     User        @relation(fields: [teacherId], references: [id])
  grades      Grade[]
  homework    Homework[]
  lessons     Lesson[]
}

model Lesson {
  id        String   @id @default(cuid())
  schoolId  String
  courseId  String
  teacherId String
  title     String
  content   String   @default("")
  fileUrl   String   @default("")
  fileName  String   @default("")
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id])
  school    School   @relation(fields: [schoolId], references: [id])
  teacher   User     @relation(fields: [teacherId], references: [id])
}

model Grade {
  id        String   @id @default(cuid())
  schoolId  String
  courseId  String
  studentId String
  teacherId String
  score     Float
  maxScore  Float    @default(20)
  trimester String   @default("1")
  comment   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id])
  school    School   @relation(fields: [schoolId], references: [id])
  student   User     @relation("GradeStudent", fields: [studentId], references: [id])
  teacher   User     @relation("GradeTeacher", fields: [teacherId], references: [id])
}

model Homework {
  id          String   @id @default(cuid())
  schoolId    String
  courseId    String
  teacherId   String
  title       String
  description String   @default("")
  dueDate     String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  course      Course   @relation(fields: [courseId], references: [id])
  school      School   @relation(fields: [schoolId], references: [id])
  teacher     User     @relation(fields: [teacherId], references: [id])
}

model Attendance {
  id        String   @id @default(cuid())
  schoolId  String
  studentId String
  teacherId String
  date      String
  status    String   @default("absent")
  reason    String   @default("")
  createdAt DateTime @default(now())
  school    School   @relation(fields: [schoolId], references: [id])
  student   User     @relation("AttendanceStudent", fields: [studentId], references: [id])
  teacher   User     @relation("AttendanceTeacher", fields: [teacherId], references: [id])

  @@unique([studentId, date])
}

model Payment {
  id        String   @id @default(cuid())
  schoolId  String
  studentId String
  amount    Float
  status    String   @default("pending")
  month     String   @default("")
  method    String   @default("cash")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id])
  student   User     @relation(fields: [studentId], references: [id])
}

model Message {
  id          String   @id @default(cuid())
  schoolId    String
  senderId    String
  recipientId String
  content     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  recipient   User     @relation("ReceivedMessages", fields: [recipientId], references: [id])
  school      School   @relation(fields: [schoolId], references: [id])
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
}

model Notification {
  id            String   @id @default(cuid())
  schoolId      String
  userId        String?
  senderId      String   @default("")
  title         String   @default("Notification")
  message       String
  type          String   @default("INFO")
  priority      String   @default("NORMAL")
  read          Boolean  @default(false)
  metadata      String   @default("{}")
  targetRole    String   @default("ALL")
  targetClassId String   @default("")
  createdAt     DateTime @default(now())
  school        School   @relation(fields: [schoolId], references: [id])
  user          User?    @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
}

model VideoConference {
  id            String   @id @default(cuid())
  schoolId      String
  title         String
  description   String   @default("")
  date          String
  time          String
  roomUrl       String
  targetRole    String   @default("ALL")
  targetClassId String   @default("")
  createdAt     DateTime @default(now())
  school        School   @relation(fields: [schoolId], references: [id])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
