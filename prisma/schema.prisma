generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model School {
  id                   String    @id @default(cuid())
  name                 String
  email                String    @unique
  password             String
  inviteCode           String    @unique
  currency             String    @default("USD")
  logoUrl              String    @default("")
  province             String    @default("")
  city                 String    @default("")
  commune              String    @default("")
  schoolCode           String    @default("")
  subscriptionStatus   String    @default("active")
  subscriptionExpiry   DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  attendance           Attendance[]
  courses              Course[]
  deliberations        DeliberationDecision[]
  detailedGrades       DetailedGrade[]
  grades               Grade[]
  gradeHistories       GradeHistory[]
  homework             Homework[]
  lessons              Lesson[]
  messages             Message[]
  notifications        Notification[]
  payments             Payment[]
  reportCards          ReportCard[]
  classes              SchoolClass[]
  schedules            CourseSchedule[]
  users                User[]
  videoConferences     VideoConference[]
  ressources           Ressource[]
  latitude             Float?
  longitude            Float?
  presences            Presence[]
  years                SchoolYear[]

  @@index([subscriptionStatus])
  @@index([inviteCode])
}

model SchoolYear {
  id             String    @id @default(cuid())
  schoolId       String
  year           String
  status         String    @default("OPEN")
  closedById     String?
  closedAt       DateTime?
  transitionData Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  school         School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, year])
  @@index([schoolId, status])
}

model User {
  id                      String    @id @default(cuid())
  schoolId                String
  fullName                String
  email                   String    @default("")
  password                String
  role                    String    @default("STUDENT")
  photoUrl                String    @default("")
  parentCode              String    @unique
  active                  Boolean   @default(true)
  parentId                String?
  phone                   String    @default("")
  parentPhone             String    @default("")
  parentPhone2            String    @default("")
  cardId                  String?   @unique
  postName                String    @default("")
  gender                  String    @default("M")
  birthDate               String    @default("")
  matricule               String    @default("")
  academicYear            String    @default("")
  section                 String    @default("")
  aiPreferences           String    @default("{}")
  isTitulaire             Boolean   @default(false)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  deletedAt               DateTime?

  conversations           AiConversation[]
  attendanceStudent       Attendance[]          @relation("AttendanceStudent")
  attendanceTeacher       Attendance[]          @relation("AttendanceTeacher")
  courses                 Course[]
  deliberations           DeliberationDecision[] @relation("DeliberationStudent")
  deliberationsValidated  DeliberationDecision[] @relation("DeliberationValidator")
  detailedGrades          DetailedGrade[]
  classEnrollments        EnrolledClass[]
  gradesStudent           Grade[]               @relation("GradeStudent")
  gradesTeacher           Grade[]               @relation("GradeTeacher")
  gradeHistoriesModified  GradeHistory[]        @relation("GradeHistoryModifier")
  homework                Homework[]
  lessons                 Lesson[]
  receivedMessages        Message[]             @relation("ReceivedMessages")
  sentMessages            Message[]             @relation("SentMessages")
  notifications           Notification[]        @relation("UserNotifications")
  payments                Payment[]
  pushSubscriptions       PushSubscription[]
  memories                AiMemory[]
  favoris                 Favori[]
  reportCards             ReportCard[]
  cahierMarks             CahierMark[]
  parent                  User?                 @relation("ParentChild", fields: [parentId], references: [id], onDelete: SetNull)
  children                User[]                @relation("ParentChild")
  school                  School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  titulaireClasses        SchoolClass[]         @relation("TitulaireClasses")
  cotationTeacher         CotationTransmission[] @relation("CotationTeacher")
  cotationTitulaire       CotationTransmission[] @relation("CotationTitulaire")
  presences               Presence[]

  @@unique([schoolId, fullName, role])
  @@index([schoolId, role, active])
  @@index([schoolId, parentId])
  @@index([schoolId, isTitulaire])
  @@index([cardId])
}

model SchoolClass {
  id               String    @id @default(cuid())
  schoolId         String
  name             String
  level            String    @default("Primaire")
  fees             Float     @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  courses          Course[]
  evaluations      CahierEvaluation[]
  enrollments      EnrolledClass[]
  reportCards      ReportCard[]
  transmissions    CotationTransmission[]
  school           School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  titulaire        User?     @relation("TitulaireClasses", fields: [titulaireId], references: [id], onDelete: SetNull)
  titulaireId      String?

  @@unique([schoolId, name])
  @@index([schoolId, level])
  @@index([titulaireId])
}

model EnrolledClass {
  id        String      @id @default(cuid())
  userId    String
  classId   String
  createdAt DateTime    @default(now())
  class     SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, classId])
  @@index([classId])
  @@index([userId])
}

model Course {
  id          String    @id @default(cuid())
  schoolId    String
  classId     String
  teacherId   String
  name        String
  maxScore    Float     @default(20)
  coefficient Int       @default(1)
  description String    @default("")
  status      String    @default("ACTIVE")
  weight      Float     @default(1.0)
  points      Int       @default(100)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  class       SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  school      School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher     User        @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  grades      Grade[]
  detailedGrades DetailedGrade[]
  evaluations CahierEvaluation[]
  homework    Homework[]
  lessons     Lesson[]
  schedules   CourseSchedule[]
  transmissions CotationTransmission[]

  @@unique([schoolId, classId, name])
  @@index([schoolId, classId, status])
  @@index([teacherId, status])
}

model Lesson {
  id        String   @id @default(cuid())
  schoolId  String
  courseId  String
  teacherId String
  title     String
  content   String   @default("")
  fileUrl   String   @default("")
  fileName  String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher   User     @relation(fields: [teacherId], references: [id], onDelete: Restrict)

  @@index([courseId, createdAt])
  @@index([schoolId, teacherId])
}

model Grade {
  id        String   @id @default(cuid())
  schoolId  String
  courseId  String
  studentId String
  teacherId String
  score     Float
  maxScore  Float    @default(20)
  trimester String   @default("1")
  comment   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student   User     @relation("GradeStudent", fields: [studentId], references: [id], onDelete: Cascade)
  teacher   User     @relation("GradeTeacher", fields: [teacherId], references: [id], onDelete: Restrict)
  history   GradeHistory[]

  @@index([schoolId, courseId, studentId, trimester])
  @@index([studentId, trimester])
  @@index([courseId, trimester])
  @@index([teacherId, trimester])
}

model Homework {
  id          String   @id @default(cuid())
  schoolId    String
  courseId    String
  teacherId   String
  title       String
  description String   @default("")
  dueDate     String   @default("")
  gradingType String   @default("manual")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher     User     @relation(fields: [teacherId], references: [id], onDelete: Restrict)

  @@index([courseId, dueDate])
  @@index([schoolId, teacherId])
}

model Attendance {
  id        String   @id @default(cuid())
  schoolId  String
  studentId String
  teacherId String
  date      String
  status    String   @default("absent")
  reason    String   @default("")
  createdAt DateTime @default(now())
  deletedAt DateTime?

  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student   User     @relation("AttendanceStudent", fields: [studentId], references: [id], onDelete: Cascade)
  teacher   User     @relation("AttendanceTeacher", fields: [teacherId], references: [id], onDelete: Restrict)

  @@unique([studentId, date])
  @@index([schoolId, date])
  @@index([schoolId, studentId])
  @@index([teacherId, date])
}

model Payment {
  id        String   @id @default(cuid())
  schoolId  String
  studentId String
  amount    Float
  status    String   @default("pending")
  month     String   @default("")
  method    String   @default("cash")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
  @@index([studentId, status])
  @@index([schoolId, month])
}

model Message {
  id          String   @id @default(cuid())
  schoolId    String
  senderId    String
  recipientId String
  content     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  deletedAt   DateTime?

  recipient   User     @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: Cascade)
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sender      User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([schoolId, recipientId, read])
  @@index([senderId, createdAt])
  @@index([recipientId, createdAt])
}

model Notification {
  id            String   @id @default(cuid())
  schoolId      String
  userId        String?
  senderId      String   @default("")
  title         String   @default("Notification")
  message       String
  type          String   @default("INFO")
  priority      String   @default("NORMAL")
  read          Boolean  @default(false)
  metadata      String   @default("{}")
  targetRole    String   @default("ALL")
  targetClassId String   @default("")
  createdAt     DateTime @default(now())
  deletedAt     DateTime?

  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user          User?    @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([schoolId, userId, read])
  @@index([schoolId, targetRole, targetClassId])
}

model VideoConference {
  id            String   @id @default(cuid())
  schoolId      String
  title         String
  description   String   @default("")
  date          String
  time          String
  roomUrl       String
  targetRole    String   @default("ALL")
  targetClassId String   @default("")
  type          String   @default("scheduled")
  status        String   @default("scheduled")
  isLocked      Boolean  @default(false)
  creatorId     String   @default("")
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime @default(now())
  deletedAt     DateTime?

  school        School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  participants  Participant[]
  recordings    Recording[]

  @@index([schoolId, status])
  @@index([schoolId, date])
}

model Participant {
  id        String   @id @default(cuid())
  meetingId String
  schoolId  String
  userId    String
  fullName  String
  role      String   @default("PARTICIPANT")
  status    String   @default("pending")
  isCoHost  Boolean  @default(false)
  joinedAt  DateTime?
  leftAt    DateTime?
  createdAt DateTime @default(now())
  deletedAt DateTime?

  meeting   VideoConference @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([schoolId, userId])
}

model Recording {
  id            String   @id @default(cuid())
  meetingId     String
  schoolId      String
  createdById   String
  url           String   @default("")
  note          String   @default("")
  durationSeconds Int    @default(0)
  createdAt     DateTime @default(now())
  deletedAt     DateTime?

  meeting       VideoConference @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  deletedAt DateTime?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AiConversation {
  id             String       @id @default(cuid())
  userId         String
  title          String       @default("Nouvelle conversation")
  salutationDone Boolean      @default(false)
  tags           String       @default("")
  favorite       Boolean      @default(false)
  pinned         Boolean      @default(false)
  pinnedAt       DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now())
  deletedAt      DateTime?

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents      AiDocument[]
  messages       AiMessage[]

  @@index([userId, pinnedAt])
  @@index([userId, updatedAt])
}

model AiMemory {
  id        String   @id @default(cuid())
  userId    String
  schoolId  String
  content   String
  category  String   @default("fact")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([schoolId, userId])
}

model Ressource {
  id            String   @id @default(cuid())
  schoolId      String
  title         String
  description   String   @default("")
  category      String   @default("Général")
  matiere       String   @default("")
  niveau        String   @default("")
  author        String   @default("")
  url           String   @default("")
  fileUrl       String   @default("")
  type          String   @default("LIEN")
  visibility    String   @default("PUBLIC")
  targetRole    String   @default("ALL")
  targetClassId String   @default("")
  createdById   String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, category])
  @@index([createdById, createdAt])
}

model Favori {
  id          String   @id @default(cuid())
  userId      String
  resourceType String
  resourceId  String
  createdAt   DateTime @default(now())
  deletedAt   DateTime?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceType, resourceId])
  @@index([userId, resourceType])
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String
  role           String
  content        String
  createdAt      DateTime       @default(now())
  deletedAt      DateTime?

  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model AiDocument {
  id             String         @id @default(cuid())
  conversationId String
  name           String
  mimeType       String
  url            String
  size           Int
  extractedText  String         @default("")
  summary        String         @default("")
  createdAt      DateTime       @default(now())
  deletedAt      DateTime?

  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model ReportCard {
  id                   String      @id @default(cuid())
  reportNumber         String      @unique
  schoolId             String
  classId              String
  studentId            String
  teacherId            String?
  trimester            String
  academicYear         String      @default("2025-2026")
  studentName          String
  studentGender        String
  studentBirthDate     String
  studentPhotoUrl      String      @default("")
  permanentNumber      String      @default("")
  totalPointsObtained  Float
  totalPointsPossible  Float
  overallPercentage    Float
  averageGrade         Float
  classRank            Int
  mention              String
  status               String      @default("draft")
  gradesData           Json
  studentSignatureUrl  String      @default("")
  parentSignatureUrl   String      @default("")
  teacherSignatureUrl  String      @default("")
  directorSignatureUrl String      @default("")
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  deletedAt            DateTime?

  class                SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  school               School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student              User        @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([schoolId, reportNumber])
  @@index([schoolId, classId, trimester])
  @@index([studentId, trimester])
}

model ReportCounter {
  id           String   @id @default(cuid())
  schoolId     String
  classId      String
  trimester    String
  count        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([schoolId, classId, trimester])
  @@index([schoolId, trimester])
}

model CourseSchedule {
  id          String    @id @default(cuid())
  courseId    String
  schoolId    String
  dayOfWeek   Int
  startTime   String
  endTime     String
  room        String    @default("")
  periodStart DateTime?
  periodEnd   DateTime?
  exceptions  String    @default("[]")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, dayOfWeek])
  @@index([courseId])
}

model GradeHistory {
  id         String   @id @default(cuid())
  gradeId    String
  schoolId   String
  oldScore   Float
  newScore   Float
  modifiedBy String
  reason     String   @default("")
  createdAt  DateTime @default(now())
  deletedAt  DateTime?

  grade      Grade    @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  modifier   User     @relation("GradeHistoryModifier", fields: [modifiedBy], references: [id])

  @@index([gradeId, createdAt])
  @@index([schoolId, modifiedBy])
}

model DeliberationDecision {
  id           String   @id @default(cuid())
  schoolId     String
  studentId    String
  classId      String
  academicYear String
  decision     String
  validatedBy  String
  comment      String   @default("")
  decidedAt    DateTime @default(now())
  deletedAt    DateTime?

  student      User     @relation("DeliberationStudent", fields: [studentId], references: [id], onDelete: Cascade)
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  validator    User     @relation("DeliberationValidator", fields: [validatedBy], references: [id])

  @@index([schoolId, classId, academicYear])
  @@index([studentId, academicYear])
}

model EPSTCurriculum {
  id          String   @id @default(cuid())
  schoolId    String
  classLevel  String
  subject     String
  topic       String
  objectives  String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@unique([schoolId, classLevel, subject, topic])
  @@index([schoolId, classLevel, subject])
}

model DetailedGrade {
  id        String   @id @default(cuid())
  schoolId  String
  studentId String
  courseId  String
  trimester String
  semester  String
  dailyWork Float    @default(0)
  exam      Float    @default(0)
  total     Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId, trimester, semester])
  @@index([schoolId, trimester, semester])
  @@index([studentId, trimester])
}

model Presence {
  id            String   @id @default(cuid())
  schoolId      String   @map("school_id")
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date          DateTime @default(now())
  heureArrivee  DateTime @map("heure_arrivee")
  statut        String
  justification String?  @map("justification")
  validePar     String?  @map("valide_par")
  latitude      Float?
  longitude     Float?
  creeLe        DateTime @default(now()) @map("cree_le")
  modifieLe     DateTime @updatedAt @map("modifie_le")
  deletedAt     DateTime?

  @@unique([userId, date])
  @@map("presences")
  @@index([schoolId, date])
  @@index([schoolId, userId, date])
}

model CahierEvaluation {
  id          String   @id @default(cuid())
  schoolId    String
  classId     String
  courseId    String
  teacherId   String
  title       String
  description String   @default("")
  maxScore    Float    @default(20)
  coefficient Int      @default(1)
  date        DateTime @default(now())
  trimester   String   @default("1")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  class       SchoolClass     @relation(fields: [classId], references: [id], onDelete: Cascade)
  course      Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  marks       CahierMark[]
  transmissions CotationTransmission[]

  @@index([schoolId, classId, courseId, trimester])
  @@index([teacherId, date])
}

model CahierMark {
  id            String   @id @default(cuid())
  evaluationId  String
  studentId     String
  score         Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  evaluation    CahierEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  student       User             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, studentId])
  @@index([studentId, createdAt])
}

model CotationTransmission {
  id                String   @id @default(cuid())
  schoolId          String
  evaluationId      String
  classId           String
  courseId          String
  teacherId         String
  titulaireId       String
  status            String   @default("PENDING") // PENDING | SENT | RECEIVED | PARTIAL | RESENT
  sentAt            DateTime?
  receivedAt        DateTime?
  lastResentAt      DateTime?
  resentCount       Int      @default(0)
  notes             String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  evaluation        CahierEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  class             SchoolClass      @relation(fields: [classId], references: [id], onDelete: Cascade)
  course            Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher           User             @relation("CotationTeacher", fields: [teacherId], references: [id], onDelete: Restrict)
  titulaire         User             @relation("CotationTitulaire", fields: [titulaireId], references: [id], onDelete: Restrict)

  @@unique([evaluationId, titulaireId])
  @@index([schoolId, classId, status])
  @@index([titulaireId, status])
  @@index([evaluationId, status])
}

